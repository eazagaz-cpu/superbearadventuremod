---
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { faqSchema, howToSchema, softwareAppSchema } from '../../utils/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const extraSchemas: object[] = [];
if (post.data.faq && post.data.faq.length > 0) {
  extraSchemas.push(faqSchema(post.data.faq));
}
if (post.data.howto) {
  extraSchemas.push(howToSchema(post.data.howto));
}
if (post.data.addSoftwareSchema) {
  extraSchemas.push(softwareAppSchema());
}
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updated={post.data.updated}
  image={post.data.image}
  category={post.data.category}
  headings={headings}
  slug={post.slug}
  extraSchemas={extraSchemas}
>
  <Content />
</BlogPost>
