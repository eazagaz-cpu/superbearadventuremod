            </div>
          </div>
        </div>

        <h2 id="six-worlds">The 6 Massive Worlds</h2>
        <p>Super Bear Adventure features six unique open-world environments, each with its own theme, enemies, secrets, and collectibles:</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 my-6 not-prose">
          {[
            { name: 'Turtletown', desc: 'Your starting hub — a peaceful town with hidden areas and friendly NPCs.', img: '/images/worlds/turtletown.svg', href: '/blog/turtletown-walkthrough/' },
            { name: 'Snow Valley', desc: 'Icy peaks with snowboard sections and frozen puzzles.', img: '/images/worlds/snow-valley.svg', href: '/blog/snow-valley-secrets/' },
            { name: 'Beemothep Desert', desc: 'Ancient ruins, sand traps, and sphinx-inspired puzzles.', img: '/images/worlds/beemothep-desert.svg', href: '/blog/beemothep-desert-puzzle/' },
            { name: 'Giant House', desc: 'Everything is oversized — navigate a world where you are tiny.', img: '/images/worlds/giant-house.svg', href: '/blog/giant-house-walkthrough/' },
            { name: 'The Hive', desc: 'A buzzing bee kingdom with honey-themed obstacles.', img: '/images/worlds/the-hive.svg', href: '/blog/the-hive-walkthrough/' },
            { name: 'Mole Mines', desc: 'Underground caverns with mining carts and gem puzzles.', img: '/images/worlds/mole-mines.svg', href: '/blog/mole-mines-walkthrough/' },
          ].map((world) => (
            <a href={world.href} class="block bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all overflow-hidden">
              <div class="w-full aspect-[4/3] overflow-hidden">
                <img src={world.img} alt={`${world.name} world in Super Bear Adventure`} width="800" height="600" class="w-full h-full object-cover" loading="lazy" decoding="async" />
              </div>
              <div class="p-4">
                <h3 class="font-bold text-gray-900 text-sm mb-1">{world.name}</h3>
                <p class="text-xs text-gray-600">{world.desc}</p>
              </div>
            </a>
          ))}
        </div>

        <h2 id="install">How to Download and Install</h2>
        <div class="my-6 space-y-4 not-prose">
          {installSteps.map((step, i) => (
            <div class="flex items-start gap-4 bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
              <div class="w-10 h-10 rounded-xl bg-game-green text-white font-bold flex items-center justify-center flex-shrink-0 text-lg">
                {i + 1}
              </div>
              <div>
