---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import QuickAnswer from '../components/QuickAnswer.astro';
import AppInfoGrid from '../components/AppInfoGrid.astro';
import EntityStrip from '../components/EntityStrip.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE } from '../utils/seo';
import { softwareAppSchema, websiteSchema, organizationSchema, howToSchema, breadcrumbSchema, faqSchema } from '../utils/schema';

const installSteps = [
  { name: 'Download the APK', text: 'Tap the Download button on this page to get the Super Bear Adventure Mod APK file.' },
  { name: 'Allow Unknown Sources', text: 'Go to Settings > Security > Enable "Install from Unknown Sources" or allow your browser to install APKs.' },
  { name: 'Install the APK', text: 'Open your file manager, find the downloaded APK, and tap to install.' },
  { name: 'Launch & Play', text: 'Open Super Bear Adventure and enjoy unlimited coins, all skins, and no ads!' },
];

const faqItems = [
  {
    question: 'Is Super Bear Adventure Mod APK safe to install?',
    answer: 'Yes, the mod APK has been scanned and verified. It does not contain malware, viruses, or any harmful code. We provide the cleanest possible build based on the official v12.1.5 release from Earthkwak Games.',
  },
  {
    question: 'Will I get banned for using the mod?',
    answer: 'The mod includes anti-ban protection. Thousands of players use it daily without issues. However, we recommend using a secondary account for online multiplayer to be extra cautious.',
  },
  {
    question: 'Does the mod work on the latest Android versions?',
    answer: 'Yes, the mod APK v12.1.5 is compatible with Android 5.1 and above, including Android 14 and 15. It works on all major phone brands including Samsung, Xiaomi, OnePlus, Pixel, and more.',
  },
  {
    question: 'Can I play multiplayer with the mod?',
    answer: 'Yes! The mod retains full multiplayer functionality from the official game. You can play co-op with friends, use invite codes, and join online sessions just like the regular version.',
  },
  {
    question: 'What is included in the mod?',
    answer: 'The mod gives you unlimited coins and gems, all skins and hats unlocked, no advertisements, all 6 game worlds accessible, full multiplayer support, and the same gameplay experience as the official v12.1.5 release.',
  },
  {
    question: 'How do I update the mod APK?',
    answer: 'When a new version is available, download the latest APK from this page and install it over the existing one. Your progress will be saved. Read our <a href="/blog/update-super-bear-adventure-mod/" class="text-game-green hover:underline">update guide</a> for step-by-step instructions.',
  },
  {
    question: 'Does it work offline?',
    answer: 'Yes, you can play single-player mode completely offline. Multiplayer mode requires an internet connection, just like the official game.',
  },
  {
    question: 'Is root access required?',
    answer: 'No, the mod APK does not require root access. It works on all standard Android devices without any special modifications.',
  },
  {
    question: 'What is the difference between the official APK and the Mod APK?',
    answer: 'The official APK is the standard game from Google Play with ads and in-app purchases. The Mod APK removes ads, gives unlimited coins, unlocks all skins/hats, and keeps the same gameplay. See our <a href="#official-apk-vs-mod" class="text-game-green hover:underline">detailed comparison table</a>.',
  },
  {
    question: 'Can I install this on iPhone/iOS?',
    answer: 'This APK is for Android only. For iOS devices, check our <a href="/blog/super-bear-adventure-ios-mod-iphone/" class="text-game-green hover:underline">iOS mod guide</a> for alternative methods.',
  },
];

const schemas = [
  softwareAppSchema(),
  websiteSchema(),
  organizationSchema(),
  howToSchema({
    name: 'How to Download and Install Super Bear Adventure Mod APK',
    description: 'Step-by-step guide to download and install the Super Bear Adventure Mod APK on your Android device.',
    steps: installSteps,
    totalTime: 'PT3M',
  }),
  breadcrumbSchema([
    { name: 'Home', url: SITE.url },
  ]),
  faqSchema(faqItems),
];
---

<BaseLayout
  title=""
  description="Download Super Bear Adventure Mod APK v12.1.5 with unlimited money, all skins unlocked, and no ads. Safe, free, updated for 2026."
  schema={schemas}
>
  <Hero />

  <main id="main-content" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid lg:grid-cols-[1fr_320px] gap-8">
    <article>
      <!-- Quick Answer Box -->
      <QuickAnswer answer={`The Super Bear Adventure Mod APK is a modified Android build aligned with official <strong>v${SITE.download.version}</strong> (${SITE.download.updated}). It gives unlimited coins, all skins and hats unlocked, no ads, and the same worlds as the Play Store game—including <a href="/blog/the-hive-walkthrough/" class="text-game-green hover:underline">The Hive</a>, Turtletown, and multiplayer.`} />

      <!-- Intro Content -->
      <div class="prose-game">
        <p class="text-lg font-medium text-gray-800">
          Super Bear Adventure Mod APK is a tweaked Android version of the game that gives you unlimited coins, all skins unlocked, and no ads while keeping the same 3D worlds and story as the official release. The latest official build is <strong>v{SITE.download.version}</strong> ({SITE.download.updated})—a multiplayer stability patch. Worlds like <a href="/blog/the-hive-walkthrough/">The Hive</a> have been in the game since Update 10.0 (2022).
