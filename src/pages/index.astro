                <p class="text-sm text-gray-600">{step.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <!-- Download CTA - outside prose-game to prevent color overrides -->
      <div class="my-8 rounded-2xl p-8 md:p-10 text-center shadow-xl border border-gray-700" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
