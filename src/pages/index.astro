            <div class="relative w-full h-44 overflow-hidden bg-gradient-to-br from-yellow-50 to-amber-50">
              <img src="/images/features/unlimited-coins.svg" alt="Unlimited coins and gems — buy everything in the shop" width="800" height="600" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
            </div>
            <div class="p-5">
