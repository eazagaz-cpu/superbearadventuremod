---
interface Props {
  title: string;
  description: string;
  slug: string;
  image?: string;
  category?: string;
  date?: string;
  readingTime?: string;
}

const { title, description, slug, image, category, date, readingTime } = Astro.props;
---

<article class="card-hover group overflow-hidden">
  {image && (
    <a href={`/blog/${slug}/`} class="block overflow-hidden aspect-video bg-gray-100">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
        decoding="async"
      />
    </a>
  )}
  <div class="p-5">
    {category && (
      <span class="inline-block px-3 py-1 text-xs font-semibold text-game-green bg-game-green-50 rounded-full mb-3">
        {category}
      </span>
    )}
    <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-game-green transition-colors line-clamp-2">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h3>
    <p class="text-sm text-gray-600 mb-4 line-clamp-2">{description}</p>
    <div class="flex items-center justify-between text-xs text-gray-400">
      {date && <time datetime={date}>{new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>}
      {readingTime && <span>{readingTime}</span>}
    </div>
  </div>
</article>
