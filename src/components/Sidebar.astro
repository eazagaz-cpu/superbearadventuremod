---
import { SITE } from '../utils/seo';

interface Props {
  showDownloadWidget?: boolean;
  showPopularGuides?: boolean;
  showTroubleshooting?: boolean;
  showSocial?: boolean;
}

const {
  showDownloadWidget = true,
  showPopularGuides = true,
  showTroubleshooting = true,
  showSocial = true,
} = Astro.props;

const popularGuides = [
  { label: 'How to Play Super Bear Adventure (Beginner)', href: '/blog/how-to-play-beginner-guide/' },
  { label: 'Download & Install Mod on PC (BlueStacks/LDPlayer)', href: '/blog/super-bear-adventure-for-pc-guide/' },
  { label: 'All Missions in Super Bear Adventure', href: '/blog/all-missions-guide/' },
  { label: 'iOS Mod on iPhone Guide', href: '/blog/super-bear-adventure-ios-mod-iphone/' },
  { label: 'Update the Mod Without Losing Progress', href: '/blog/update-super-bear-adventure-mod/' },
  { label: 'All 15 Hidden Stickers Locations', href: '/blog/all-secret-stickers-locations/' },
  { label: 'Turtletown Walkthrough', href: '/blog/turtletown-walkthrough/' },
  { label: 'Fix Lag & Common Errors', href: '/blog/lag-fix-optimization/' },
];

const downloadSetup = [
  { label: 'Download & Install Mod on PC (BlueStacks/LDPlayer)', href: '/blog/super-bear-adventure-for-pc-guide/' },
  { label: 'iOS Mod on iPhone Guide', href: '/blog/super-bear-adventure-ios-mod-iphone/' },
  { label: 'Old Versions Archive', href: '/blog/super-bear-adventure-mod-apk-old-versions/' },
  { label: 'Update Without Losing Progress', href: '/blog/update-super-bear-adventure-mod/' },
  { label: 'Mod Menu Features Guide', href: '/blog/super-bear-adventure-mod-menu/' },
];

const moreGuides = [
  { label: 'Unlock All Hats and Skins: Customization Guide', href: '/blog/unlock-all-skins-hats/' },
  { label: 'Secret Areas & Easter Eggs: What Most Players Miss', href: '/blog/secret-areas-easter-eggs/' },
  { label: 'Get Unlimited Coins Fast (Legal vs Mod Tips)', href: '/blog/unlimited-coins-farming/' },
  { label: 'Arcade World Mini-Games: Win Every Reward', href: '/blog/arcade-world-mini-games/' },
];

const troubleshooting = [
  { label: 'Multiplayer: Online Play Guide', href: '/blog/multiplayer-guide/' },
  { label: 'Fix Lag: Optimization for Low-End Devices', href: '/blog/lag-fix-optimization/' },
  { label: 'Common Errors: App Not Installed & Black Screen', href: '/blog/troubleshooting-common-errors/' },
  { label: 'Best Games Like Super Bear Adventure', href: '/blog/best-games-like-sba/' },
  { label: 'Lore: The Story of Baaren & Purple Honey', href: '/blog/lore-baaren-story/' },
  { label: 'Redeem Codes 2026: Active Codes', href: '/blog/redeem-codes-list/' },
  { label: 'Version Change Logs: What\'s New in Every Update', href: '/blog/version-changelogs/' },
];
---

<aside class="sidebar-container space-y-6">
  <!-- Popular Guides Widget -->
  {showPopularGuides && (
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="flex items-center gap-2 px-5 py-4 bg-gradient-to-r from-game-green-50 to-emerald-50 border-b border-gray-100">
        <svg class="w-5 h-5 text-game-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        <h3 class="text-sm font-bold text-gray-900">Popular Guides</h3>
      </div>
      <div class="p-3">
        {popularGuides.map((guide) => (
          <a href={guide.href} class="flex items-start gap-2.5 px-3 py-2.5 rounded-xl text-sm text-gray-600 hover:bg-game-green-50 hover:text-game-green transition-colors group">
            <svg class="w-4 h-4 mt-0.5 text-game-green/50 group-hover:text-game-green flex-shrink-0 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            <span class="leading-snug">{guide.label}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Download & Setup Widget -->
  {showDownloadWidget && (
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="flex items-center gap-2 px-5 py-4 bg-gradient-to-r from-game-green-50 to-emerald-50 border-b border-gray-100">
        <svg class="w-5 h-5 text-game-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <h3 class="text-sm font-bold text-gray-900">Download & Setup</h3>
      </div>
      <div class="p-4">
        <a href={SITE.download.url} class="w-full flex items-center justify-center gap-2 px-4 py-3.5 font-extrabold text-sm rounded-xl hover:brightness-110 transition-all mb-3 border-0" style="background: #86c943; color: #ffffff; box-shadow: 0 5px 0 #4f8f2f, 0 6px 12px rgba(79,143,47,0.3); text-shadow: 0 1px 2px rgba(0,0,0,0.15);">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download APK v{SITE.download.version}
        </a>
        <div class="flex items-center justify-center gap-4 text-xs text-gray-500 mb-4">
          <span>{SITE.download.size}</span>
          <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
          <span>{SITE.download.requires}</span>
          <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
          <span>Free</span>
        </div>
        <div class="space-y-0.5">
          {downloadSetup.map((item) => (
            <a href={item.href} class="flex items-start gap-2.5 px-3 py-2.5 rounded-xl text-sm text-gray-600 hover:bg-game-green-50 hover:text-game-green transition-colors group">
              <svg class="w-4 h-4 mt-0.5 text-game-green/50 group-hover:text-game-green flex-shrink-0 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
              <span class="leading-snug">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- More Guides Widget -->
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="flex items-center gap-2 px-5 py-4 bg-gradient-to-r from-game-green-50 to-emerald-50 border-b border-gray-100">
      <svg class="w-5 h-5 text-game-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      <h3 class="text-sm font-bold text-gray-900">More Guides</h3>
    </div>
    <div class="p-3">
      {moreGuides.map((guide) => (
        <a href={guide.href} class="flex items-start gap-2.5 px-3 py-2.5 rounded-xl text-sm text-gray-600 hover:bg-game-green-50 hover:text-game-green transition-colors group">
          <svg class="w-4 h-4 mt-0.5 text-game-green/50 group-hover:text-game-green flex-shrink-0 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
          <span class="leading-snug">{guide.label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Troubleshooting Widget -->
  {showTroubleshooting && (
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="flex items-center gap-2 px-5 py-4 bg-gradient-to-r from-game-green-50 to-emerald-50 border-b border-gray-100">
        <svg class="w-5 h-5 text-game-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <h3 class="text-sm font-bold text-gray-900">Troubleshooting</h3>
      </div>
      <div class="p-3">
        {troubleshooting.map((item) => (
          <a href={item.href} class="flex items-start gap-2.5 px-3 py-2.5 rounded-xl text-sm text-gray-600 hover:bg-game-green-50 hover:text-game-green transition-colors group">
            <svg class="w-4 h-4 mt-0.5 text-game-green/50 group-hover:text-game-green flex-shrink-0 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            <span class="leading-snug">{item.label}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Social Links Widget -->
  {showSocial && (
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <div class="flex items-center gap-2 px-5 py-4 bg-gradient-to-r from-game-green-50 to-emerald-50 border-b border-gray-100">
        <svg class="w-5 h-5 text-game-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <h3 class="text-sm font-bold text-gray-900">Follow Us</h3>
      </div>
      <div class="p-5">
        <div class="grid grid-cols-5 gap-2">
          <a href={SITE.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 hover:bg-red-600 text-gray-500 hover:text-white transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12z"/></svg>
          </a>
          <a href={SITE.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="X" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 hover:bg-gray-900 text-gray-500 hover:text-white transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 hover:bg-blue-600 text-gray-500 hover:text-white transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 hover:bg-gradient-to-br hover:from-purple-600 hover:to-pink-500 text-gray-500 hover:text-white transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={SITE.social.pinterest} target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 hover:bg-red-700 text-gray-500 hover:text-white transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641 0 12.017 0z"/></svg>
          </a>
          <a href={SITE.social.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 hover:bg-gray-900 text-gray-500 hover:text-white transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
          <a href={SITE.social.reddit} target="_blank" rel="noopener noreferrer" aria-label="Reddit" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 hover:bg-orange-600 text-gray-500 hover:text-white transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 6.627 5.373 12 12 12s12-5.373 12-12c0-6.627-5.373-12-12-12zm6.066 9.645c.183.996-.238 1.906-.956 2.37.017.131.025.264.025.398 0 3.396-3.953 6.15-8.828 6.15-4.876 0-8.828-2.754-8.828-6.15 0-.137.009-.272.027-.406-.701-.47-1.113-1.372-.932-2.362.27-1.473 1.661-2.464 3.107-2.214.445.077.847.254 1.185.501C4.93 7.183 7.353 6.602 9.95 6.552l1.676-7.927a.36.36 0 01.429-.282l5.602 1.188a2.056 2.056 0 013.973.791 2.056 2.056 0 01-2.985 1.834l-4.89-1.036-1.5 7.089c2.567.063 4.957.648 6.92 1.624.332-.242.727-.416 1.165-.492 1.446-.25 2.837.74 3.107 2.214v.001zM8.5 12.645a1.5 1.5 0 100 3 1.5 1.5 0 000-3zm7 0a1.5 1.5 0 100 3 1.5 1.5 0 000-3z"/></svg>
          </a>
          <a href={SITE.social.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 hover:bg-green-600 text-gray-500 hover:text-white transition-all">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
