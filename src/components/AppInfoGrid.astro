---
import { SITE } from '../utils/seo';

const infoItems = [
  { icon: 'update', label: 'Last Updated', value: SITE.download.updated },
  { icon: 'version', label: 'Version', value: `v${SITE.download.version}` },
  { icon: 'size', label: 'Size', value: SITE.download.size },
  { icon: 'android', label: 'Requires', value: SITE.download.requires },
  { icon: 'developer', label: 'Developer', value: SITE.download.developer },
  { icon: 'category', label: 'Category', value: SITE.download.category },
  { icon: 'rating', label: 'Rating', value: `${SITE.download.rating}★ (883K+ reviews)` },
  { icon: 'downloads', label: 'Downloads', value: SITE.download.downloads },
  { icon: 'price', label: 'Price', value: SITE.download.price },
];

const iconPaths: Record<string, string> = {
  update: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  version: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z',
  size: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4',
  android: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z',
  developer: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  category: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
  rating: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
  downloads: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4',
  price: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
};

const iconColors: Record<string, string> = {
  update: 'bg-emerald-500',
  version: 'bg-blue-500',
  size: 'bg-purple-500',
  android: 'bg-green-600',
  developer: 'bg-indigo-500',
  category: 'bg-orange-500',
  rating: 'bg-yellow-500',
  downloads: 'bg-teal-500',
  price: 'bg-rose-500',
};
---

<section class="my-10" aria-labelledby="app-info-heading">
  <h2 id="app-info-heading" class="text-xl font-bold text-gray-900 mb-5">Super Bear Adventure Quick Info</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    {infoItems.map((item) => (
      <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
        <span class:list={['flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center text-white', iconColors[item.icon]]}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[item.icon]} />
          </svg>
        </span>
        <div class="flex flex-col gap-0.5 min-w-0">
          <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{item.label}</span>
          <span class="text-sm font-semibold text-emerald-700 break-words">{item.value}</span>
        </div>
      </div>
    ))}
  </div>
</section>
