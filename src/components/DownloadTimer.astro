---
import { SITE } from '../utils/seo';
---

<!-- Inline Download Countdown - no modal, no popup -->
<script is:inline define:vars={{ downloadUrl: SITE.download.url }}>
(function() {
  var activeBtn = null;
  var countdownInterval = null;

  function startCountdown(btn) {
    if (activeBtn) return;
    activeBtn = btn;

    var origHTML = btn.innerHTML;
    var seconds = 5;

    btn.setAttribute('aria-live', 'polite');
    btn.style.pointerEvents = 'none';
    btn.innerHTML = 'Preparing download in ' + seconds + 's...';

    countdownInterval = setInterval(function() {
      seconds--;
      if (seconds > 0) {
        btn.innerHTML = 'Preparing download in ' + seconds + 's...';
      } else {
        clearInterval(countdownInterval);
        countdownInterval = null;

        btn.innerHTML = 'Download Started...';

        var a = document.createElement('a');
        a.href = downloadUrl;
        a.style.display = 'none';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);

        setTimeout(function() {
          btn.innerHTML = 'Download Complete';
        }, 600);

        setTimeout(function() {
          btn.innerHTML = 'Restart Download';
          btn.style.pointerEvents = '';
          activeBtn = null;
        }, 1800);
      }
    }, 1000);
  }

  document.addEventListener('click', function(e) {
    var link = e.target.closest('a[href="' + downloadUrl + '"]');
    if (link) {
      e.preventDefault();
      startCountdown(link);
    }
  });
})();
</script>
