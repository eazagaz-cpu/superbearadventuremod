---
interface Props {
  question?: string;
  answer: string;
}

const {
  question = 'What is Super Bear Adventure Mod APK?',
  answer,
} = Astro.props;
---

<aside class="quick-answer-box my-8 bg-gradient-to-br from-game-green-50 to-emerald-50 border-2 border-game-green/20 rounded-2xl p-6 md:p-8" id="quick-answer" aria-labelledby="quick-answer-label">
  <div class="flex items-start gap-3 mb-3">
    <div class="w-8 h-8 rounded-lg bg-game-green/10 flex items-center justify-center flex-shrink-0 mt-0.5">
      <svg class="w-5 h-5 text-game-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    <div>
      <p class="text-xs font-bold uppercase tracking-wider text-game-green mb-1" id="quick-answer-label">Quick Answer</p>
      <p class="text-sm font-semibold text-gray-700">{question}</p>
    </div>
  </div>
  <div class="text-gray-700 leading-relaxed pl-11">
    <Fragment set:html={answer} />
  </div>
</aside>
