---
import { SITE } from '../utils/seo';
import { breadcrumbSchema } from '../utils/schema';

interface Props {
  items: { name: string; href?: string }[];
}

const { items } = Astro.props;

const schemaItems = [
  { name: 'Home', url: SITE.url },
  ...items.map((item) => ({
    name: item.name,
    url: item.href ? new URL(item.href, SITE.url).toString() : '',
  })),
];
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-gray-500">
    <li>
      <a href="/" class="hover:text-game-green transition-colors flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        Home
      </a>
    </li>
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        {index === items.length - 1 ? (
          <span class="text-gray-700 font-medium">{item.name}</span>
        ) : (
          <a href={item.href} class="hover:text-game-green transition-colors">{item.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(schemaItems))} />
