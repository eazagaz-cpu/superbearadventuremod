---
import { SITE } from '../utils/seo';
---

<section class="relative overflow-hidden bg-gradient-to-br from-game-green via-game-green-dark to-emerald-900 py-16 md:py-24" aria-label="Hero">
  <!-- Background decoration (static, no animations for performance) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-game-green-light/10 rounded-full" style="filter:blur(60px);"></div>
    <div class="absolute -bottom-32 -left-32 w-[400px] h-[400px] bg-emerald-400/8 rounded-full" style="filter:blur(60px);"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Content Column -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 rounded-full text-sm text-white/90 mb-6 border border-white/10">
          <span class="w-2 h-2 bg-game-green-light rounded-full animate-pulse"></span>
          Updated {SITE.download.updated}
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white leading-tight mb-6">
          Super Bear Adventure
          <span class="block text-game-green-light">Mod APK v{SITE.download.version}</span>
        </h1>

        <p class="text-lg md:text-xl text-white/80 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          Unlimited Coins &middot; All Skins Unlocked &middot; No Ads &middot; Official {SITE.download.version} build
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-10">
          <a href={SITE.download.url} class="btn-download group">
            <svg class="w-6 h-6 dl-icon group-hover:animate-bounce" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            <span>Download APK v{SITE.download.version}<span class="block text-sm font-semibold opacity-70">({SITE.download.size}) Free &middot; No Root</span></span>
          </a>
          <a href="#install" class="inline-flex items-center gap-2 px-6 py-4 bg-white/10 text-white font-bold text-lg rounded-2xl border-2 border-white/20 hover:bg-white/20 hover:border-white/40 transition-all duration-300">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            How to Install
          </a>
        </div>

        <!-- Trust Signals -->
        <div class="flex flex-wrap items-center gap-3 justify-center lg:justify-start mb-8">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/10 rounded-full text-sm text-white/90 border border-white/10">
            <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Virus Free
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/10 rounded-full text-sm text-white/90 border border-white/10">
            <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Fully Unlocked
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/10 rounded-full text-sm text-white/90 border border-white/10">
            <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Anti-Ban
          </span>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-3 gap-4 max-w-md mx-auto lg:mx-0">
          <div class="text-center lg:text-left">
            <p class="text-2xl md:text-3xl font-extrabold text-white">{SITE.download.downloads}</p>
            <p class="text-xs md:text-sm text-white/60">Downloads</p>
          </div>
          <div class="text-center lg:text-left">
            <p class="text-2xl md:text-3xl font-extrabold text-white">{SITE.download.rating}<span class="text-yellow-400">★</span></p>
            <p class="text-xs md:text-sm text-white/60">Rating</p>
          </div>
          <div class="text-center lg:text-left">
            <p class="text-2xl md:text-3xl font-extrabold text-white">v{SITE.download.version}</p>
            <p class="text-xs md:text-sm text-white/60">Latest</p>
          </div>
        </div>

        <!-- v12.1.5 Update Badge -->
        <div class="mt-6 flex justify-center lg:justify-start">
          <a href="/blog/version-changelogs/" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 rounded-full text-sm text-white/90 border border-white/10 hover:bg-white/20 transition-all">
            <span class="w-2 h-2 bg-game-green-light rounded-full animate-pulse"></span>
            v{SITE.download.version} Update
          </a>
        </div>
      </div>

      <!-- Screenshot / Visual Column -->
      <div class="hidden lg:flex justify-center items-center">
        <div class="relative">
          <!-- Game screenshot placeholder - replace src with real gameplay screenshot -->
          <div class="w-80 h-[420px] rounded-3xl border-2 border-white/15 overflow-hidden shadow-2xl shadow-black/30 bg-gradient-to-b from-white/10 to-white/5">
            <img
              src="/images/real/hero-vertical.jpg"
              alt="Super Bear Adventure Mod APK — Baaren with unlimited coins in the Kingdom of Earthkwak"
              width="640"
              height="840"
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
          <!-- Floating badges -->
          <div class="absolute -top-4 -right-4 px-4 py-2 bg-yellow-400 text-yellow-900 font-bold text-sm rounded-xl shadow-lg">
            FREE
          </div>
          <div class="absolute -bottom-4 -left-4 px-5 py-2.5 bg-white text-gray-900 font-bold text-sm rounded-xl shadow-lg flex items-center gap-2">
            <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            No Ads &middot; No Root
          </div>
          <div class="absolute top-4 -left-4 px-4 py-2 bg-gradient-to-r from-purple-500 to-pink-500 text-white font-bold text-xs rounded-xl shadow-lg">
            v{SITE.download.version} Latest
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
