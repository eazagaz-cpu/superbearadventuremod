---
import { SITE } from '../utils/seo';
---

<section class="relative overflow-hidden bg-gradient-to-br from-game-green via-game-green-dark to-emerald-900 py-16 md:py-24" aria-label="Hero">
  <!-- Animated background shapes -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-game-green-light/10 rounded-full blur-3xl animate-pulse-soft"></div>
    <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-emerald-400/10 rounded-full blur-3xl animate-pulse-soft" style="animation-delay: 2s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-game-green-light/5 rounded-full blur-3xl"></div>
    <!-- Floating particles -->
    <div class="absolute top-20 left-[10%] w-3 h-3 bg-yellow-400/30 rounded-full animate-float" style="animation-delay: 0s;"></div>
    <div class="absolute top-40 right-[20%] w-2 h-2 bg-green-300/40 rounded-full animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute bottom-32 left-[30%] w-4 h-4 bg-amber-300/20 rounded-full animate-float" style="animation-delay: 2s;"></div>
    <div class="absolute top-32 right-[40%] w-2.5 h-2.5 bg-lime-300/30 rounded-full animate-float" style="animation-delay: 3s;"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Content Column -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 backdrop-blur-sm rounded-full text-sm text-white/90 mb-6 border border-white/10">
          <span class="w-2 h-2 bg-game-green-light rounded-full animate-pulse"></span>
          Updated {SITE.download.updated}
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white leading-tight mb-6">
          Super Bear Adventure
          <span class="block text-game-green-light">Mod APK v{SITE.download.version}</span>
        </h1>

        <p class="text-lg md:text-xl text-white/80 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          Unlimited Coins &middot; All Skins Unlocked &middot; No Ads &middot; Official {SITE.download.version} build
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-10">
          <a href={SITE.download.url} class="btn-download group">
            <svg class="w-6 h-6 group-hover:animate-bounce" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download APK ({SITE.download.size})
          </a>
          <a href="#install" class="btn-secondary !bg-white/10 !text-white !border-white/20 hover:!bg-white/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            How to Install
          </a>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-3 gap-4 max-w-md mx-auto lg:mx-0">
          <div class="text-center lg:text-left">
            <p class="text-2xl md:text-3xl font-extrabold text-white">{SITE.download.downloads}</p>
            <p class="text-xs md:text-sm text-white/60">Downloads</p>
          </div>
          <div class="text-center lg:text-left">
            <p class="text-2xl md:text-3xl font-extrabold text-white">{SITE.download.rating}<span class="text-yellow-400">★</span></p>
            <p class="text-xs md:text-sm text-white/60">Rating</p>
          </div>
          <div class="text-center lg:text-left">
            <p class="text-2xl md:text-3xl font-extrabold text-white">v{SITE.download.version}</p>
            <p class="text-xs md:text-sm text-white/60">Latest</p>
          </div>
        </div>
      </div>

      <!-- Mascot Column -->
      <div class="hidden lg:flex justify-center items-center">
        <div class="relative">
          <div class="w-80 h-96 bg-white/5 rounded-3xl border border-white/10 backdrop-blur-sm flex items-center justify-center animate-float">
            <!-- Placeholder for mascot image - replace with actual image -->
            <svg class="w-48 h-48 text-white/20" viewBox="0 0 200 240" xmlns="http://www.w3.org/2000/svg">
              <ellipse cx="100" cy="80" rx="35" ry="30" fill="#795548"/>
              <ellipse cx="70" cy="55" rx="18" ry="18" fill="#795548"/>
              <ellipse cx="130" cy="55" rx="18" ry="18" fill="#795548"/>
              <ellipse cx="70" cy="55" rx="12" ry="12" fill="#a1887f"/>
              <ellipse cx="130" cy="55" rx="12" ry="12" fill="#a1887f"/>
              <ellipse cx="100" cy="85" rx="20" ry="18" fill="#a1887f"/>
              <ellipse cx="100" cy="78" rx="10" ry="7" fill="#4e342e"/>
              <circle cx="87" cy="68" r="5" fill="#4e342e"/>
              <circle cx="113" cy="68" r="5" fill="#4e342e"/>
              <circle cx="89" cy="66" r="2" fill="white"/>
              <circle cx="115" cy="66" r="2" fill="white"/>
              <path d="M92 95 Q100 105 108 95" stroke="#4e342e" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <ellipse cx="100" cy="160" rx="45" ry="60" fill="#795548"/>
              <ellipse cx="100" cy="165" rx="35" ry="40" fill="#a1887f"/>
              <ellipse cx="65" cy="160" rx="12" ry="30" fill="#795548" transform="rotate(-10 65 160)"/>
              <ellipse cx="135" cy="160" rx="12" ry="30" fill="#795548" transform="rotate(10 135 160)"/>
              <ellipse cx="80" cy="215" rx="15" ry="10" fill="#795548"/>
              <ellipse cx="120" cy="215" rx="15" ry="10" fill="#795548"/>
              <!-- Red bow tie -->
              <path d="M85 115 L100 125 L115 115 L115 130 L100 120 L85 130 Z" fill="#e53935"/>
              <circle cx="100" cy="122" r="4" fill="#c62828"/>
            </svg>
          </div>
          <!-- Floating badges -->
          <div class="absolute -top-4 -right-4 px-4 py-2 bg-yellow-400 text-yellow-900 font-bold text-sm rounded-xl shadow-lg animate-bounce-slow">
            FREE
          </div>
          <div class="absolute -bottom-4 -left-4 px-4 py-2 bg-white text-game-green-dark font-bold text-sm rounded-xl shadow-lg">
            No Ads ✓
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
