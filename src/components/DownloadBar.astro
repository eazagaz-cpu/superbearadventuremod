---
import { SITE } from '../utils/seo';
---

<div class="fixed bottom-0 left-0 right-0 z-40 bg-gray-900 border-t border-gray-700 shadow-[0_-4px_30px_rgba(0,0,0,0.3)]" id="download-bar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 md:h-[72px] gap-4">
      <!-- Info -->
      <div class="hidden sm:flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-game-green/20 flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
            <circle cx="32" cy="32" r="28" fill="#795548"/>
            <ellipse cx="32" cy="32" rx="12" ry="14" fill="#a1887f"/>
            <ellipse cx="32" cy="30" rx="4" ry="3" fill="#4e342e"/>
            <circle cx="27" cy="26" r="2" fill="#4e342e"/>
            <circle cx="37" cy="26" r="2" fill="#4e342e"/>
          </svg>
        </div>
        <div>
          <p class="text-white font-bold text-sm md:text-base leading-tight">Super Bear Adventure Mod APK</p>
          <p class="text-gray-400 text-xs md:text-sm">v{SITE.download.version} &middot; {SITE.download.size} &middot; Free</p>
        </div>
      </div>

      <!-- Download Button -->
      <a
        href={SITE.download.url}
        class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2.5 px-8 md:px-10 py-3 md:py-3.5 text-white font-extrabold text-sm md:text-base rounded-xl hover:scale-[1.03] active:scale-100 transition-all border-0"
        style="background: linear-gradient(to bottom, #8BC34A, #558B2F); box-shadow: 0 4px 0 #33691E, 0 6px 14px rgba(51,105,30,0.4);"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Download APK v{SITE.download.version}
      </a>
    </div>
  </div>
</div>
