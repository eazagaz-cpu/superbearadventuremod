---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DownloadTimer from '../components/DownloadTimer.astro';
import type { SEOProps } from '../utils/seo';
import { SITE } from '../utils/seo';
import '../styles/global.css';

interface Props extends SEOProps {
  schema?: object | object[];
}

const { schema, ...seoProps } = Astro.props;
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <SEOHead {...seoProps} />
    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
    <!-- Google Analytics - deferred loading -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-PNDYPNJVF2"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PNDYPNJVF2');
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-game-green focus:text-white focus:rounded-lg">
      Skip to main content
    </a>
    <Header />
    <slot />
    <Footer />
    <DownloadTimer />
  </body>
</html>
