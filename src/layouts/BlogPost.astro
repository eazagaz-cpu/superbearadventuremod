---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TableOfContents from '../components/TableOfContents.astro';
import SocialShare from '../components/SocialShare.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE } from '../utils/seo';
import { articleSchema } from '../utils/schema';

interface Props {
  title: string;
  description: string;
  date: string;
  updated?: string;
  image?: string;
  category?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
}

const { title, description, date, updated, image, category, headings, slug } = Astro.props;

const pageUrl = `${SITE.url}/blog/${slug}/`;
const readingTime = Math.max(1, Math.ceil(Astro.slots.has('default') ? 8 : 5));

const schema = articleSchema({
  title,
  description,
  url: pageUrl,
  image: image ? `${SITE.url}${image}` : undefined,
  datePublished: date,
  dateModified: updated || date,
});
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={image}
  publishedTime={date}
  modifiedTime={updated || date}
  schema={schema}
>
  <main id="main-content" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={[{ name: 'Blog', href: '/blog/' }, { name: title }]} />

    <div class="grid lg:grid-cols-[1fr_300px] gap-8">
      <!-- Main Content -->
      <article class="min-w-0">
        <!-- Article Header -->
        <header class="mb-8">
          {category && (
            <span class="inline-block px-3 py-1 text-xs font-semibold text-game-green bg-game-green-50 rounded-full mb-4">
              {category}
            </span>
          )}
          <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4 leading-tight">{title}</h1>
          <p class="text-lg text-gray-600 mb-4">{description}</p>
          <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
            <time datetime={date} class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {new Date(date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
            {updated && (
              <span class="flex items-center gap-1.5 text-game-green">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Updated {new Date(updated).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
            )}
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {readingTime} min read
            </span>
          </div>

          <SocialShare url={pageUrl} title={title} />
        </header>

        <!-- Featured Image -->
        {image && (
          <div class="mb-8 rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
            <img
              src={image}
              alt={title}
              width="800"
              height="450"
              class="w-full h-auto"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        )}

        <!-- Article Body -->
        <div class="prose-game">
          <slot />
        </div>

        <!-- Bottom CTA -->
        <div class="mt-12 rounded-2xl p-8 text-center border border-gray-700" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background: rgba(134,201,67,0.15);">
            <svg class="w-7 h-7" style="color: #86c943;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </div>
          <h2 style="color: #ffffff !important; font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem;">Download Super Bear Adventure Mod APK</h2>
          <p style="color: #9ca3af; margin-bottom: 1.5rem;">v{SITE.download.version} &middot; Unlimited Coins &middot; All Skins &middot; No Ads</p>
          <a href={SITE.download.url} class="btn-download">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download Super Bear Adventure Mod APK Now
          </a>
          <div class="flex items-center justify-center gap-4 mt-4" style="font-size: 0.75rem; color: #9ca3af;">
            <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" style="color: #4ade80;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg> Safe</span>
            <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" style="color: #4ade80;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg> Free</span>
            <span class="flex items-center gap-1"><svg class="w-3.5 h-3.5" style="color: #4ade80;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg> No Root</span>
          </div>
        </div>

        <SocialShare url={pageUrl} title={title} />
      </article>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <TableOfContents headings={headings} />
          <Sidebar showPopularGuides={true} showDownloadWidget={true} showTroubleshooting={false} showSocial={false} />
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>
