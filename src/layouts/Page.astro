---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  breadcrumb?: string;
}

const { title, description, breadcrumb } = Astro.props;
---

<BaseLayout title={title} description={description} showDownloadBar={false}>
  <main id="main-content" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={[{ name: breadcrumb || title }]} />
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6">{title}</h1>
    <div class="prose-game">
      <slot />
    </div>
  </main>
</BaseLayout>
